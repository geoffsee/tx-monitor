{
    "name": "tx-monitor",
    "version": "1.0.16",
    "description": "Real-time network traffic visualizer powered by tcpdump and WebSockets",
    "license": "MIT",
    "type": "module",
    "workspaces": [
        "packages/*"
    ],
    "bin": {
        "tx-monitor": "bin/tx-monitor.js"
    },
    "files": [
        "bin",
        "dist",
        "drizzle",
        "src",
        "README.md"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/geoffsee/tx-monitor.git"
    },
    "keywords": [
        "tcpdump",
        "network",
        "traffic",
        "monitor",
        "visualizer",
        "websocket"
    ],
    "engines": {
        "bun": ">=1.0.0"
    },
    "scripts": {
        "build": "bun run build.ts",
        "compile": "bun build --compile src/server.ts --outfile build/tx-monitor",
        "dev": "vite",
        "monitor": "bun run src/server.ts",
        "monitor:file": "bun run src/server.ts --file tcpdump.log",
        "start": "bun run src/server.ts",
        "start:file": "bun run src/server.ts --file tcpdump.log",
        "prepack": "bun run build && bun run verify:publish",
        "verify:publish": "bun run scripts/verify-publish.ts",
        "test": "bun test",
        "typecheck": "tsc --noEmit",
        "db:generate": "drizzle-kit generate",
        "db:push": "drizzle-kit push",
        "lint": "biome check .",
        "lint:fix": "biome check --write .",
        "format": "biome format --write .",
        "check:fix": "biome check --write .",
        "check:staged": "biome check --staged --write --no-errors-on-unmatched",
        "postinstall": "./.dev/setup-git-hooks.sh"
    },
    "devDependencies": {
        "@biomejs/biome": "2.5.0",
        "@types/bun": "latest",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "drizzle-kit": "^0.31.10",
        "typescript": "^7.0.2",
        "vite": "^8.0.10"
    },
    "dependencies": {
        "@openai/codex-sdk": "^0.139.0",
        "@xyflow/react": "^12.10.2",
        "drizzle-orm": "^0.45.2",
        "mobx": "^6.15.0",
        "mobx-state-tree": "^7.2.0",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "tx-mon-sdk": "workspace:*"
    }
}
